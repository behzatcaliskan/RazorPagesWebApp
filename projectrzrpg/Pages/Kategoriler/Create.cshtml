@page
@model projectrzrpg.Pages.Kategoriler.CreateModel

@{
    Layout = "_AdminLayout";
}

<h2 class="mb-4">Kategori Ekle</h2>

<form method="post">

    <div class="form-group mb-3">
        <label>Kategori Adı</label>
        <input type="text" name="KategoriAdi" class="form-control" required />
    </div>

    <div class="form-group mb-3">
        <label>Açıklama</label>
        <input type="text" name="Aciklama" class="form-control" required />
    </div>

    <div class="form-group mb-3">
        <label>Durum</label>
        <select name="Durum" class="form-control">
            <option value="Aktif">Aktif</option>
            <option value="Pasif">Pasif</option>
        </select>
    </div>

    <button type="submit" class="btn btn-success">
        Kaydet
    </button>

    <a href="/Kategoriler/Index" class="btn btn-secondary">
        Listeye Dön
    </a>

</form>
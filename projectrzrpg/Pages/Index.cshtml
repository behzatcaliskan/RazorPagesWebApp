@page
@model projectrzrpg.Pages.IndexModel

@{
    Layout = "_AdminLayout";
}

<h1 class="h3 mb-4 text-gray-800">Yönetim Paneli</h1>

<div class="row">

    <!-- Yöneticiler Kartı -->
    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">

                <div class="row no-gutters align-items-center">

                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Yönetici İşlemleri
                        </div>

                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            Yönetici Kayıtları
                        </div>

                        <p class="mt-2 mb-0 text-gray-600">
                            Yönetici bilgilerini ekleyebilir, listeleyebilir, güncelleyebilir ve silebilirsiniz.
                        </p>
                    </div>

                    <div class="col-auto">
                        <i class="fas fa-users fa-2x text-gray-300"></i>
                    </div>

                </div>

                <a href="/yoneticiler/Index" class="btn btn-primary btn-sm mt-3">
                    Yönetici Listesine Git
                </a>

            </div>
        </div>
    </div>

    <!-- Kategoriler Kartı -->
    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">

                <div class="row no-gutters align-items-center">

                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            Kategori İşlemleri
                        </div>

                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            Kategori Kayıtları
                        </div>

                        <p class="mt-2 mb-0 text-gray-600">
                            Kategorileri ekleyebilir, düzenleyebilir ve kayıt durumlarını takip edebilirsiniz.
                        </p>
                    </div>

                    <div class="col-auto">
                        <i class="fas fa-folder fa-2x text-gray-300"></i>
                    </div>

                </div>

                <a href="/Kategoriler/Index" class="btn btn-success btn-sm mt-3">
                    Kategori Listesine Git
                </a>

            </div>
        </div>
    </div>

    <!-- Raporlar Kartı -->
    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">

                <div class="row no-gutters align-items-center">

                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            Raporlama
                        </div>

                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            Panel Raporları
                        </div>

                        <p class="mt-2 mb-0 text-gray-600">
                            Yönetici ve kategori kayıtlarına ait özet bilgilere ulaşabilirsiniz.
                        </p>
                    </div>

                    <div class="col-auto">
                        <i class="fas fa-chart-bar fa-2x text-gray-300"></i>
                    </div>

                </div>

                <a href="/Raporlar" class="btn btn-warning btn-sm mt-3">
                    Raporları Görüntüle
                </a>

            </div>
        </div>
    </div>

</div>


<!-- Panel Bilgilendirme Alanı -->
<div class="row mt-2">

    <div class="col-lg-12 mb-3">
        <div class="card shadow">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    Panel Bilgilendirme
                </h6>
            </div>

            <div class="card-body">
                <p class="mb-0 text-gray-700">
                    Bu yönetim panelinde Yöneticiler ve Kategoriler tabloları için temel CRUD işlemleri yapılmaktadır.
                    Sol menüden ilgili sayfalara geçiş yapılabilir, kayıtlar listelenebilir, yeni kayıt eklenebilir,
                    mevcut kayıtlar güncellenebilir ve silinebilir.
                </p>
            </div>
        </div>
    </div>

</div>


<!-- Alt Özellik Kartları -->
<div class="row">

    <div class="col-lg-4 mb-4">
        <div class="card shadow h-100">
            <div class="card-body text-center">

                <i class="fas fa-database fa-3x text-primary mb-3"></i>

                <h5 class="font-weight-bold text-gray-800">
                    Veri Yönetimi
                </h5>

                <p class="text-gray-600 mb-0">
                    Veritabanındaki yönetici ve kategori kayıtları panel üzerinden düzenli şekilde yönetilir.
                </p>

            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-4">
        <div class="card shadow h-100">
            <div class="card-body text-center">

                <i class="fas fa-tasks fa-3x text-success mb-3"></i>

                <h5 class="font-weight-bold text-gray-800">
                    CRUD İşlemleri
                </h5>

                <p class="text-gray-600 mb-0">
                    Listeleme, ekleme, güncelleme ve silme işlemleri ayrı Razor Pages sayfaları ile yapılır.
                </p>

            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-4">
        <div class="card shadow h-100">
            <div class="card-body text-center">

                <i class="fas fa-chart-pie fa-3x text-warning mb-3"></i>

                <h5 class="font-weight-bold text-gray-800">
                    Raporlama
                </h5>

                <p class="text-gray-600 mb-0">
                    Raporlar sayfasında toplam kayıt sayıları ve paneldeki tablo özetleri görüntülenir.
                </p>

            </div>
        </div>
    </div>

</div>